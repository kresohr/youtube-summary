# Database
DB_USER=youtubesummary
DB_PASSWORD=secure_password_here
DB_NAME=youtube_summary_db

# Authentication
JWT_SECRET=generate_with_openssl_rand_base64_32

# APIs
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API key — primary AI engine (Tier 1 & 2 summaries)
# Get your key for free at: https://aistudio.google.com/app/apikey
# The CLI is invoked headlessly via node_modules/.bin/gemini with GEMINI_API_KEY
# injected into the child process. No interactive login required.
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API key — Tier 3 last-resort fallback only
# Used when Gemini CLI is unavailable or returns an error.
# Completely optional if GEMINI_API_KEY is set.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# App
APP_URL=https://yourdomain.com/fetch
CORS_ORIGIN=https://yourdomain.com

# Server
NODE_ENV=production
PORT=4000

# Nginx / SSL (production profile)
HTTP_PORT=80
HTTPS_PORT=443
SSL_CERT_PATH=/etc/letsencrypt
